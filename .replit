modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[userenv]

[userenv.shared]
"VITE_API_BASE=" = "https://macharia-os-main.replit.app"
VITE_API_BASE = "https://macharia-os-main.replit.app"
PORT = "5000"
BASE_PATH = "/"
NODE_OPTIONS = "--max-http-header-size=65536"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_OPTIONS='--max-http-header-size=65536' PORT=5000 BASE_PATH=/ pnpm --filter @workspace/founders-brand-hub run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"
