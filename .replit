modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/sponsorship-hub"

[[artifacts]]
id = "artifacts/founders-kitchen"

[[artifacts]]
id = "artifacts/founders-gaming"

[[artifacts]]
id = "artifacts/fvc"

[[artifacts]]
id = "artifacts/founders-brand-hub"

[[artifacts]]
id = "artifacts/chapters-ledgers"

[userenv]

[userenv.shared]
"VITE_API_BASE=" = "https://macharia-os-main.replit.app"
VITE_API_BASE = "https://macharia-os-main.replit.app"
PORT = "5000"
BASE_PATH = "/"
NODE_OPTIONS = "--max-http-header-size=65536"
MACHARIA_OS_PARTNER_KEY = "fbf_mike_75c26acb49019442b78b7a58922edbaf"
TIMESHEET_ADMIN_PARTNER_KEY = "fbf_mike_75c26acb49019442b78b7a58922edbaf"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/sponsorship-hub: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/founders-kitchen: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/founders-gaming: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/fvc: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/founders-brand-hub: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/chapters-ledgers: web"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/api-server: API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "API_PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/sponsorship-hub: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/sponsorship-hub run dev"

[workflows.workflow.metadata]
outputType = "webview"

